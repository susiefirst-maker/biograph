# Frontend environment — copy to .env.local, fill in real values.
# .env.local is gitignored by the create-next-app template.

# Backend API base URL. Server components fetch from this origin; the
# SearchBar (client component) hits it too, which requires the backend's
# CORS_ORIGINS to include this frontend's public URL.
#
# Local dev:
NEXT_PUBLIC_BIOGRAPH_API_URL=http://localhost:8000

# Production (Vercel env): set to the backend's public URL, e.g.
#   NEXT_PUBLIC_BIOGRAPH_API_URL=https://biograph-api.fly.dev
