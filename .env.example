# BioGraph environment — copy to .env, fill in real values.
# .env is gitignored (see .gitignore). .env.example is committed.

# ── Database ────────────────────────────────────────────────
POSTGRES_DB=biograph
POSTGRES_USER=biograph
POSTGRES_PASSWORD=biograph_dev
DATABASE_URL=postgresql+asyncpg://biograph:biograph_dev@localhost:5432/biograph
# Alembic uses the sync driver; the app uses the async driver.
DATABASE_URL_SYNC=postgresql+psycopg2://biograph:biograph_dev@localhost:5432/biograph

# ── Meilisearch ─────────────────────────────────────────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=biograph_dev_key

# ── Redis (Celery broker) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic Claude API ───────────────────────────────────
# Optional: only needed for narrative-compilation workflows.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_SPEND_USD=50

# ── External scientific APIs ───────────────────────────────
# Open Targets GraphQL — no auth, reasonable-use rate limit.
OPEN_TARGETS_URL=https://api.platform.opentargets.org/api/v4/graphql

# ClinicalTrials.gov v2 — no auth, 100 req/min.
CLINICAL_TRIALS_URL=https://clinicaltrials.gov/api/v2

# FDA openFDA — no auth (rate-limited heavier without key).
FDA_URL=https://api.fda.gov

# SEC EDGAR requires a User-Agent with contact info. Replace with your contact URL.
SEC_USER_AGENT="BioGraph/0.1 contact-form"

# PubMed E-utilities — API key optional but recommended (10 req/sec with key).
PUBMED_API_KEY=

# DrugBank — paid tier, pending approval. Leave empty until received.
DRUGBANK_API_KEY=

# USPTO PatentsView — free tier, requires registration at
# https://patentsview.org/api-key-request.
PATENTSVIEW_API_KEY=

# UniProt / ChEMBL / bioRxiv — no auth required.

# ── Budget + ops guards ────────────────────────────────────
# Fail ingestion if a single LLM call exceeds this token budget.
LLM_PER_CALL_MAX_TOKENS=4000

# ── Deploy (production overrides) ──────────────────────────
# Comma-separated allowed CORS origins. Must include the frontend's
# production URL or /api/search calls from the browser will fail.
#   dev:  CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
#   prod: CORS_ORIGINS="https://biograph.app,https://www.biograph.app"
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
